# ──────────────────────────────────────────────────────────
# La Poste Modular — Environment Variables Template
# ──────────────────────────────────────────────────────────
# Copy to .env (dev) or .env.prod (production)
# and fill in the actual values.
# ──────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=laposte_modular
POSTGRES_USER=laposte_admin
POSTGRES_PASSWORD=<your-database-password>

# ── pgAdmin (dev only) ───────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@swiftapp.ch
PGADMIN_DEFAULT_PASSWORD=<your-pgadmin-password>

# ── Mail ──────────────────────────────────────────────────
MAIL_HOST=<smtp-host>
MAIL_PORT=<smtp-port>
MAIL_USERNAME=<smtp-username>
MAIL_PASSWORD=<smtp-password>
MAIL_FROM=noreply@laposte.ch

# ── Keycloak ─────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<keycloak-admin-password>

# ── Application ──────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
APP_PORT=8080

