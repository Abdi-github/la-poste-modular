# ──────────────────────────────────────────────────────────
# La Poste Modular — Development Environment Variables
# ──────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=laposte_modular
POSTGRES_USER=laposte_admin
POSTGRES_PASSWORD=laposte_secret

# ── pgAdmin ──────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@swiftapp.ch
PGADMIN_DEFAULT_PASSWORD=admin

# ── Mail (Mailpit — local email catcher) ─────────────────
MAIL_HOST=localhost
MAIL_PORT=1028
MAIL_FROM=noreply@laposte.ch

# ── Keycloak ─────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin


# ── Application ──────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
APP_PORT=8080

# ── Keycloak ──────────────────────────────────────────
KEYCLOAK_CLIENT_ID=la-poste
KEYCLOAK_CLIENT_SECRET=6liIgiNlw8F2dQQNqLi7N2aa8HrpNS0H
# When running app on host (make dev-infra), both URLs are the same
KEYCLOAK_EXTERNAL_URI=https://localhost:8071/realms/la-poste
KEYCLOAK_INTERNAL_URI=https://localhost:8071/realms/la-poste
KEYCLOAK_ISSUER_URI=http://0.0.0.0:8071/realms/la-poste


